DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

GITHUB_CLIENT_ID="your_github_oauth_client_id"
GITHUB_CLIENT_SECRET="your_github_oauth_client_secret"

BETTER_AUTH_SECRET="generate_a_random_secret"
# Base URL of your app (must match your public URL exactly, no trailing slash)
BETTER_AUTH_URL="http://localhost:3000"

GITHUB_APP_ID="your_github_app_id"
GITHUB_APP_NAME="your_github_app_name"
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# Must match the "Webhook secret" in your GitHub App settings
GITHUB_WEBHOOK_SECRET="your_github_webhook_secret"

# Set to 1 when running Inngest locally with `npx inngest-cli dev`
INNGEST_DEV=1

# Create an index with integrated embeddings: model llama-text-embed-v2, field map text=text
PINECONE_API_KEY="your_pinecone_api_key"
PINECONE_INDEX="your_pinecone_index_name"

OPENROUTER_API_KEY="your_openrouter_api_key"
